{
  "manifest_version": 3,
  "name": "YouTube Doubt Collector",
  "version": "1.0",
  "description": "Save doubts with YouTube timestamps",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://www.youtube.com/*"
  ]
}